[app]
title = Mini Game Paradise
package.name = minigameparadise
package.domain = org.junyoung
source.dir = .
source.include_exts = py, ttf
version = 0.1
requirements = python3, library, kivy
orientation = portrait
fullscreen = 1
android.archs = arm64-v8a, armeabi-v7a
android.allow_backup = True
android.api = 33
android.minapi = 24
android.ndk_api = 24

[buildozer]
log_level = 2
warn_on_root = 1
